<h2 class="text-lg font-semibold mb-4">Step 6 of 6 — Confirm</h2>

<div class="bg-white border rounded-lg p-5 mb-6 space-y-3 text-sm">
  <div class="grid grid-cols-2 gap-x-4 gap-y-2">
    <div><span class="text-gray-500">Weather:</span> <%= @resolver.weather_label %></div>
    <div><span class="text-gray-500">Health:</span> <%= @resolver.health_label %></div>
  </div>

  <hr class="border-gray-100">

  <div class="grid grid-cols-2 gap-x-4 gap-y-2">
    <div>
      <span class="text-gray-500">Food:</span>
      <%= @resolver.town.food %>
      &minus;<%= @resolver.food_consumed %>
      +<%= @resolver.food_hits %>
      &rarr; <strong><%= @resolver.new_food %></strong>
    </div>
    <div>
      <span class="text-gray-500">Materials:</span>
      <%= @resolver.town.materials %>
      +<%= @resolver.material_hits %>
      &rarr; <strong><%= @resolver.new_materials %></strong>
    </div>
    <div>
      <span class="text-gray-500">Happiness:</span>
      <%= @resolver.town.happiness %>
      (<%= @resolver.total_happiness_delta >= 0 ? '+' : '' %><%= @resolver.total_happiness_delta %>)
      &rarr; <strong><%= @resolver.new_happiness %></strong>
    </div>
    <div>
      <span class="text-gray-500">Population:</span>
      <strong><%= @resolver.new_population %></strong>
    </div>
  </div>

  <hr class="border-gray-100">

  <div>
    <span class="text-gray-500">Week <%= @resolver.town.week %></span>
    &rarr; <strong>Week <%= @resolver.town.week + 1 %></strong>
  </div>
</div>

<%= form_with url: confirm_week_advance_path, method: :post, data: { turbo_frame: "_top" } do |f| %>
  <%= f.submit "Advance Week", class: "bg-stone-800 text-white px-6 py-2 rounded hover:bg-stone-700 cursor-pointer font-semibold" %>
<% end %>
