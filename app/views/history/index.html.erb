<div class="max-w-4xl mx-auto p-6">
  <h1 class="text-2xl font-bold mb-6">History</h1>

  <% if @week_logs.empty? %>
    <p class="text-gray-500">No weeks logged yet.</p>
  <% else %>
    <div class="space-y-4">
      <% @week_logs.each do |log| %>
        <div class="bg-white border rounded-lg p-5 shadow-sm">
          <h2 class="text-lg font-semibold mb-3">Week <%= log.week_number %></h2>

          <div class="grid grid-cols-2 gap-x-8 gap-y-1 text-sm mb-3">
            <div><span class="text-gray-500">Weather:</span> <%= log.weather_effect %> (rolled <%= log.weather_roll %>)</div>
            <div><span class="text-gray-500">Health:</span> <%= log.health_effect %> (rolled <%= log.health_roll %>)</div>
            <div><span class="text-gray-500">Food:</span> <%= log.food_start %> &rarr; <%= log.food_end %> (−<%= log.food_consumed %>, +<%= log.food_gathered %>)</div>
            <div><span class="text-gray-500">Materials:</span> <%= log.materials_start %> &rarr; <%= log.materials_end %> (+<%= log.materials_gathered %>)</div>
            <div><span class="text-gray-500">Happiness:</span> <%= log.happiness_start %> &rarr; <%= log.happiness_end %></div>
            <div><span class="text-gray-500">Workers:</span> <%= log.available_workers %> / <%= log.population_start %></div>
          </div>

          <% if log.notes.present? %>
            <p class="text-sm text-gray-600 mt-2"><%= log.notes %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
